  "htmlContent": "<div style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;background:#ffffff;'>{{ IF lang == 'en' }}<h2 style='color:#2c3e50;'>🔑 Password Reset</h2><p>Hello!</p><p>You requested a password reset. Click the button below:</p><p style='margin:25px 0;text-align:center;'><a href='{{ task.settings.link }}' style='display:inline-block;padding:14px 28px;background:#3498db;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>Reset Password</a>&nbsp;&nbsp;<a href='https://t.me/hq_vpn_bot/web' style='display:inline-block;padding:14px 28px;background:#0088cc;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>📱 Telegram</a></p><table style='margin:15px 0;border-collapse:collapse;width:100%;'><tr style='background:#f8f9fa;'><td style='padding:8px 12px;border:1px solid #dee2e6;'>📧 Email</td><td style='padding:8px 12px;border:1px solid #dee2e6;'><b>{{ to_email }}</b></td></tr><tr><td style='padding:8px 12px;border:1px solid #dee2e6;'>⏰ Valid for</td><td style='padding:8px 12px;border:1px solid #dee2e6;'><b>1 hour</b></td></tr></table><p style='color:#7f8c8d;font-size:13px;'>Or copy this link:<br><a href='{{ task.settings.link }}' style='color:#3498db;word-break:break-all;'>{{ task.settings.link }}</a></p><p style='color:#e74c3c;font-size:13px;'>⚠️ If you did not request a password reset, please ignore this message.</p><p style='margin-top:30px;color:#95a5a6;font-size:12px;'>Best regards,<br>HQ VPN Team</p>{{ ELSE }}<h2 style='color:#2c3e50;'>🔑 Сброс пароля</h2><p>Здравствуйте!</p><p>Вы запросили сброс пароля. Нажмите на кнопку ниже:</p><p style='margin:25px 0;text-align:center;'><a href='{{ task.settings.link }}' style='display:inline-block;padding:14px 28px;background:#3498db;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>Сбросить пароль</a>&nbsp;&nbsp;<a href='https://t.me/hq_vpn_bot/web' style='display:inline-block;padding:14px 28px;background:#0088cc;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>📱 Telegram</a></p><table style='margin:15px 0;border-collapse:collapse;width:100%;'><tr style='background:#f8f9fa;'><td style='padding:8px 12px;border:1px solid #dee2e6;'>📧 Email</td><td style='padding:8px 12px;border:1px solid #dee2e6;'><b>{{ to_email }}</b></td></tr><tr><td style='padding:8px 12px;border:1px solid #dee2e6;'>⏰ Ссылка действительна</td><td style='padding:8px 12px;border:1px solid #dee2e6;'><b>1 час</b></td></tr></table><p style='color:#7f8c8d;font-size:13px;'>Или скопируйте ссылку:<br><a href='{{ task.settings.link }}' style='color:#3498db;word-break:break-all;'>{{ task.settings.link }}</a></p><p style='color:#e74c3c;font-size:13px;'>⚠️ Если вы не запрашивали сброс пароля, просто проигнорируйте это сообщение.</p><p style='margin-top:30px;color:#95a5a6;font-size:12px;'>С уважением,<br>Команда HQ VPN</p>{{ END }}</div>"
