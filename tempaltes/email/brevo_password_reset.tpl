{{ lang = user.settings.lang || 'ru' }}{
  "sender": {"name": "HQ VPN", "email": "noreply@z-hq.com"},
  "to": [{"email": "{{ task.settings.to }}", "name": "{{ user.full_name || user.login }}"}],
  "subject": "{{ IF lang == 'en' }}🔑 Password Reset{{ ELSE }}🔑 Сброс пароля{{ END }}",
  "htmlContent": "<div style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;background:#ffffff;'>{{ IF lang == 'en' }}<h2 style='color:#2c3e50;'>🔑 Password Reset</h2><p>Hello, <b>{{ user.full_name || user.login }}</b>!</p><p>You requested a password reset. Click the button below:</p><p style='margin:25px 0;text-align:center;'><a href='{{ task.settings.link }}' style='display:inline-block;padding:14px 28px;background:#3498db;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>Reset Password</a></p><p style='color:#7f8c8d;font-size:13px;'>Or copy this link:<br><a href='{{ task.settings.link }}' style='color:#3498db;word-break:break-all;'>{{ task.settings.link }}</a></p><p style='color:#7f8c8d;font-size:13px;'>This link is valid for <b>1 hour</b>.</p><p style='color:#e74c3c;font-size:13px;'>If you did not request a password reset, please ignore this message.</p><p style='margin-top:30px;color:#95a5a6;font-size:12px;'>Best regards,<br>HQ VPN Team</p>{{ ELSE }}<h2 style='color:#2c3e50;'>🔑 Сброс пароля</h2><p>Здравствуйте, <b>{{ user.full_name || user.login }}</b>!</p><p>Вы запросили сброс пароля. Нажмите на кнопку ниже:</p><p style='margin:25px 0;text-align:center;'><a href='{{ task.settings.link }}' style='display:inline-block;padding:14px 28px;background:#3498db;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;'>Сбросить пароль</a></p><p style='color:#7f8c8d;font-size:13px;'>Или скопируйте ссылку:<br><a href='{{ task.settings.link }}' style='color:#3498db;word-break:break-all;'>{{ task.settings.link }}</a></p><p style='color:#7f8c8d;font-size:13px;'>Ссылка действительна <b>1 час</b>.</p><p style='color:#e74c3c;font-size:13px;'>Если вы не запрашивали сброс пароля, просто проигнорируйте это сообщение.</p><p style='margin-top:30px;color:#95a5a6;font-size:12px;'>С уважением,<br>Команда HQ VPN</p>{{ END }}</div>"
}
